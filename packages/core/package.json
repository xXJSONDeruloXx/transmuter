{
  "name": "@transmuter/core",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "build:esm": "tsup src/index.ts --format esm --sourcemap --clean --no-dts --tsconfig tsconfig.build.json",
    "dev": "tsup --watch",
    "check-deps": "depcruise src --config .dependency-cruiser.cjs"
  },
  "dependencies": {
    "@ast-grep/lang-cpp": "^0.0.6",
    "@ast-grep/napi": "^0.36.0",
    "diff": "^8.0.4",
    "objdiff-wasm": "^3.0.0",
    "tree-sitter-c": "^0.21.4",
    "tree-sitter-pascal": "github:Isopod/tree-sitter-pascal"
  },
  "devDependencies": {
    "@types/diff": "^7.0.2",
    "dependency-cruiser": "^17.3.10",
    "tsup": "^8.0.0"
  }
}
