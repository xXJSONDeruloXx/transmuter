{
  "name": "@transmuter/core",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./slot-worker": {
      "import": "./dist/search/slot-worker.js"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "bun": ">=1.3.12"
  },
  "scripts": {
    "build": "bun run build.ts && tsc --emitDeclarationOnly --project tsconfig.build.json",
    "build:esm": "bun run build.ts",
    "dev": "bun --watch run build.ts",
    "check-deps": "depcruise src --config .dependency-cruiser.cjs"
  },
  "dependencies": {
    "@ast-grep/lang-cpp": "^0.0.6",
    "@ast-grep/napi": "^0.36.0",
    "diff": "^8.0.4",
    "objdiff-wasm": "^3.0.0",
    "tree-sitter-c": "^0.21.4",
    "tree-sitter-pascal": "github:Isopod/tree-sitter-pascal"
  },
  "devDependencies": {
    "@types/diff": "^7.0.2",
    "dependency-cruiser": "^17.3.10"
  }
}
